# Platform backend — copy to .env. Never commit real secrets.
# See docs/v1-delivery.md for pilot install notes.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pentest_platform
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Optional OpenAI-compatible LLM (platform-side helpers only; execution is Node4).
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# Optional: persist schedules to a JSON file (default: in-memory per process)
# NODE4_SCHEDULE_STORE=/var/lib/my-ai-pen/schedules.json
