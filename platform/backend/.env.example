DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pentest_platform
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Platform Agent LLM for orchestration, completed-session Q&A, and result explanation.
# OpenAI-compatible API; during MVP this can reuse the same provider/key as node/.env.
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
