NODE_NAME=pentest-pi-01
NODE_TOKEN=
PLATFORM_WS_URL=ws://localhost:8000/ws
NODE2_WORKSPACE=./workspace
PI_AGENT_DIR=./.pi-agent
# Optional absolute or process-cwd-relative overrides. Defaults are resolved from the node2 package root.
# NODE2_SKILLS_DIR=./skills
# NODE2_WORKFLOWS_DIR=./workflows
# NODE2_POC_CATALOG=./poc-catalog/web-vulns.json
# PI_WORKFLOW_PACKAGE_DIR=./node_modules/@agwab/pi-workflow

PI_MODEL_PROVIDER=openai
PI_MODEL=gpt-5

# OpenAI
OPENAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Custom LLM
# PI_MODEL_PROVIDER=custom
# PI_MODEL=your-model-id
LLM_BASE_URL=
LLM_API=openai-completions
LLM_API_KEY=
# LLM_CONTEXT_WINDOW=128000
# LLM_MAX_TOKENS=8192

# Traffic truth / proxy integration
# Route Node2 http/browser/verifier traffic through a proxy.
# NODE2_TRAFFIC_PROXY_URL=http://127.0.0.1:8080

# Use an already-running traffic source bridge.
# NODE2_EXTERNAL_TRAFFIC_SOURCE_URL=http://127.0.0.1:48180
# NODE2_EXTERNAL_TRAFFIC_SOURCE_TOKEN=

# Or let Node2 auto-start the Caido traffic bridge for each task.
# With NODE2_CAIDO_SIDECAR_AUTO=1, Node2 also starts the Strix/Caido Docker sidecar
# and routes Node2 browser/http/verifier traffic through it.
# NODE2_CAIDO_BRIDGE_AUTO=1
# NODE2_CAIDO_BRIDGE_HOST=127.0.0.1
# NODE2_CAIDO_BRIDGE_PORT=48180
# NODE2_CAIDO_BRIDGE_PYTHON=D:\Coding\my-ai-pen\research\strix\.venv\Scripts\python.exe
# NODE2_CAIDO_BRIDGE_SCRIPT=D:\Coding\my-ai-pen\node2\bridges\caido_traffic_bridge.py
# STRIX_CAIDO_URL=http://127.0.0.1:48080
# NODE2_CAIDO_SIDECAR_AUTO=1
# NODE2_CAIDO_SIDECAR_IMAGE=ghcr.io/usestrix/strix-sandbox:1.0.0
# NODE2_CAIDO_SIDECAR_HOST=127.0.0.1
# NODE2_CAIDO_SIDECAR_PORT=
