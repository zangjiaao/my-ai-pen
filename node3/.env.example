# Docker mode: use host.docker.internal when the platform backend runs on the host.
PLATFORM_WS_URL=ws://host.docker.internal:8000/ws
NODE_TOKEN=
NODE_NAME=pentest-strix-01

# Strix adapter defaults. Leave unset locally to use node3/workspace/strix_runtime.
STRIX_PROJECT_DIR=/workspace/node3/workspace/strix_runtime
STRIX_SCAN_MODE=quick
# STRIX_COMMAND=strix
# STRIX_EXTRA_ARGS=--max-budget-usd 1

# Strix reads model/provider settings directly.
# STRIX_LLM=openai/gpt-5
# LLM_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
