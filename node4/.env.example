# Node4 runtime — copy to .env and fill values. Do not commit secrets.

NODE_NAME=node-dev-1
NODE_TOKEN=
PLATFORM_WS_URL=ws://127.0.0.1:8000/ws/node

# Model (example: deepseek via compatible API)
PI_MODEL_PROVIDER=deepseek
PI_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

PI_AGENT_DIR=.pi-agent

# Optional continue / goal lab knobs (see docs/node4-harness.md)
# NODE4_MAX_CONTINUES=16
# NODE4_MAX_PREMATURE_STOPS=3
# NODE4_MAX_GOAL_CONTINUES=   # unset = unlimited while goal active
