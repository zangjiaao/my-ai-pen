# Node5 CLI — copy to .env. Prefer same model keys as node4/.env.
# Do not commit secrets.

# Model (match Node4)
PI_MODEL_PROVIDER=deepseek
PI_MODEL=deepseek-v4-flash

# OpenAI-compatible gateway (OpenCode Go — same as Node4)
# NOT /v1 (website) and NOT /zen/v1 (Zen payg) when using OpenCode Go sub.
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API=openai-completions
LLM_API_KEY=
# LLM_CONTEXT_WINDOW=128000
# LLM_MAX_TOKENS=8192

# Optional per-stage LLM call budget (tool loops)
# NODE5_STAGE_MAX_LLM_CALLS=24
